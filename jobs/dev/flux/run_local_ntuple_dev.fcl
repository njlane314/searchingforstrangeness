#include "microboone_eventweight_service.fcl"
#include "redk2nu.fcl"
#include "eventweight_microboone_sept24_numi_fhc.fcl"
#include "run_nuselection_slim.fcl"

process_name: LocalNtupleDev

services.TFileService.fileName: "local_ntuple_dev.root"
services.UBEventWeight: @local::microboone_eventweight_service
services.NuRandomService: @local::microboone_seedservice

# This local path follows the standard NuMI EventWeight configuration from
# ubsim and the standard g4_10_4 redk2nu lookup from ubana/redk2nu.

physics.producers.imageprod: @local::standard_image_producer

physics.producers.generator: @local::microboone_redk2nu_fhc
physics.producers.eventweightSep24: @local::microboone_eventweight_sept24

physics.path1: [ generator, eventweightSep24, imageprod, nuselection ]
physics.trigger_paths: [ path1 ]

LocalNtupleEventWeightAnalysis: {
  @table::EventWeightAnalysis
  genieAllUniverses: 100
  ppfxAllUniverses: 100
  useReweightedFlux: false
  eventWeightProcessName00: "LocalNtupleDev"
}

physics.filters.nuselection.AnalysisTools.weight: @local::LocalNtupleEventWeightAnalysis
physics.filters.nuselection.CountWithOpFilter: false
physics.filters.nuselection.OpFilterProcName: ""

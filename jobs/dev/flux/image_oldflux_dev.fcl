#include "microboone_eventweight_service.fcl"
#include "redk2nu_g4_9_2.fcl"
#include "eventweight_microboone_sept24_numi_fhc_oldflux_rw.fcl"
#include "run_nuselection_oldflux.fcl"

process_name: ImagingOldFluxDev

services.TFileService.fileName: "imaging_oldflux_dev.root"
services.UBEventWeight: @local::microboone_eventweight_service
services.NuRandomService: @local::microboone_seedservice

physics.producers.generator: @local::microboone_redk2nu_fhc
physics.producers.eventweightSep24: @local::microboone_eventweight_sept24_oldflux
physics.producers.inferenceprod: @local::standard_inference_producer

physics.path1: [ generator, eventweightSep24, imageprod, inferenceprod, nuselection ]
physics.trigger_paths: [ path1 ]

EventWeightAnalysisOldFluxDev: @local::EventWeightAnalysisOldFlux
EventWeightAnalysisOldFluxDev.genieAllUniverses: 100
EventWeightAnalysisOldFluxDev.ppfxAllUniverses: 100
EventWeightAnalysisOldFluxDev.eventWeightProcessName00: "ImagingOldFluxDev"

physics.filters.nuselection.AnalysisTools.weight: @local::EventWeightAnalysisOldFluxDev
physics.filters.nuselection.CountWithOpFilter: false
physics.filters.nuselection.OpFilterProcName: ""

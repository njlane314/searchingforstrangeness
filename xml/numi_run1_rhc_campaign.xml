<?xml version="1.0"?>

<!DOCTYPE project [
    <!ENTITY release "v08_00_00_92">
    <!ENTITY user "nlane">
    <!ENTITY name "numi_run1_rhc_campaign">
    <!ENTITY initsrc "runtime/scripts/initsrc.sh">

    <!ENTITY tar_dir "/pnfs/uboone/scratch/users/nlane/tarballs">
    <!ENTITY larsoft_tar "&tar_dir;/strangeness.tar">

    <!ENTITY input_beam "ub_numi_run1_rhc_beam_gr">
    <!ENTITY input_dirt "ub_numi_run1_rhc_dirt_gr">

    <!ENTITY fcl_redk2nu_old "run_redk2nu_v4_9_2_rhc.fcl">
    <!ENTITY fcl_evtw_old_00 "run_eventweight_microboone_sept24_numi_rhc_oldflux_rw.fcl">
    <!ENTITY fcl_image "run_imageprod.fcl">
    <!ENTITY fcl_sel_mc_old "run_nuselection_noinference_oldflux.fcl">
]>

<job>
<project name="&name;">

    <numevents>-1</numevents>
    <os>SL7</os>
    <resource>DEDICATED,OPPORTUNISTIC,OFFSITE</resource>
    <larsoft>
        <tag>&release;</tag>
        <qual>e17:prof</qual>
        <local>&larsoft_tar;</local>
    </larsoft>
    <check>1</check>
    <copy>0</copy>
    <version>prod_&release;</version>
    <memory>4000</memory>
    <disk>20GB</disk>
    <schema>https</schema>
    <maxfilesperjob>1</maxfilesperjob>

    <stage name="beam_evtw">
        <inputdef>&input_beam;</inputdef>
        <fcl>&fcl_redk2nu_old;</fcl>
        <fcl>&fcl_evtw_old_00;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/evtw/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/evtw/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/beam/run1_rhc/evtw</workdir>
        <datatier>eventweight</datatier>
        <numjobs>1</numjobs>
    </stage>

    <stage name="beam_image">
        <previousstage>beam_evtw</previousstage>
        <fcl>&fcl_image;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/image/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/image/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/beam/run1_rhc/image</workdir>
        <datatier>image</datatier>
        <numjobs>1</numjobs>
    </stage>

    <stage name="beam_sel">
        <previousstage>beam_image</previousstage>
        <fcl>&fcl_sel_mc_old;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/sel/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run1_rhc/sel/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/beam/run1_rhc/sel</workdir>
        <datatier>selected</datatier>
        <numjobs>1</numjobs>
    </stage>

    <stage name="dirt_evtw">
        <inputdef>&input_dirt;</inputdef>
        <fcl>&fcl_redk2nu_old;</fcl>
        <fcl>&fcl_evtw_old_00;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/evtw/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/evtw/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/dirt/run1_rhc/evtw</workdir>
        <datatier>eventweight</datatier>
        <numjobs>1</numjobs>
    </stage>

    <stage name="dirt_image">
        <previousstage>dirt_evtw</previousstage>
        <fcl>&fcl_image;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/image/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/image/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/dirt/run1_rhc/image</workdir>
        <datatier>image</datatier>
        <numjobs>1</numjobs>
    </stage>

    <stage name="dirt_sel">
        <previousstage>dirt_image</previousstage>
        <fcl>&fcl_sel_mc_old;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/sel/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run1_rhc/sel/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/dirt/run1_rhc/sel</workdir>
        <datatier>selected</datatier>
        <numjobs>1</numjobs>
    </stage>

</project>
</job>

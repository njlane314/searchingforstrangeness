<?xml version="1.0"?>

<!DOCTYPE project [
    <!ENTITY release "v08_00_00_82">
    <!ENTITY user "nlane">
    <!ENTITY name "numi_reco2_run2a_fhc_campaign">
    <!ENTITY initsrc "runtime/scripts/initsrc.sh">

    <!ENTITY tar_dir "/pnfs/uboone/scratch/users/nlane/tarballs">
    <!ENTITY larsoft_tar "&tar_dir;/strangeness.tar">

    <!--
      Official Run 2a FHC Reco2 source SAM definitions from the March 2022 NuMI
      dataset list, plus the dedicated Run 2 FHC strangeness overlay.

      The same list also shows a regenerated beam entry,
      run2_numi_nu_overlay_pandora_unified_reco2_run2b_rhc_reco2, under the
      Run 2a FHC block. Because that definition is explicitly RHC-tagged and is
      duplicated under Run 2b RHC, this template defaults to the clearly
      FHC-tagged source below.
    -->
    <!ENTITY input_beam_campaign_run2a_fhc "prodgenie_numi_overlay_detvar_CV_run2_FHC_standard_nu_reco2_v08_00_00_55_run2_reco2">
    <!ENTITY input_dirt_campaign_run2a_fhc "prodgenie_numi_fhc_dirt_overlay_pandora_reco2_run2_reco2">
    <!ENTITY input_strangeness_campaign_run2a_fhc "prod_strange_resample_fhc_run2_fhc_reco2_reco2">
    <!ENTITY input_ext_campaign_run2a_fhc "prod_extnumi_swizzle_inclusive_v4_run2a_reco2_run2a_all_reco2">
    <!ENTITY input_data_campaign_run2a_fhc "prod_numi_swizzle_inclusive_v4_run2_reco2_run2a_beam_good_reco2">

    <!ENTITY fcl_evtw_00 "run_eventweight_microboone_sept24_numi_fhc_oldflux_rw.fcl">
    <!ENTITY fcl_evtw_01 "run_eventweight_microboone_sept24_extragenieall_1_numi_fhc_oldflux_rw.fcl">
    <!ENTITY fcl_evtw_02 "run_eventweight_microboone_sept24_extragenieall_2_numi_fhc_oldflux_rw.fcl">
    <!ENTITY fcl_evtw_03 "run_eventweight_microboone_sept24_extragenieall_3_numi_fhc_oldflux_rw.fcl">
    <!ENTITY fcl_evtw_04 "run_eventweight_microboone_sept24_extragenieall_4_numi_fhc_oldflux_rw.fcl">
    <!ENTITY fcl_evtw_05 "run_eventweight_microboone_sept24_extragenieall_5_numi_fhc_oldflux_rw.fcl">

    <!--
      Temporary campaign settings:
      keep only fcl_evtw_00 so these jobs write the first 100 multisim
      universes, use the NuMI old-flux reweighting chain, and skip inference
      until the checked-in models are updated.

      The March 2022 list warns that good-runs were not yet applied to the Run
      2a samples. If you want filtered or partitioned definitions, derive them
      upstream and replace the input entities here.
    -->
    <!ENTITY fcl_image "run_imageprod.fcl">
    <!ENTITY fcl_infer "run_inferenceprod.fcl">
    <!ENTITY fcl_sel_mc "run_nuselection_noinference.fcl">
    <!ENTITY fcl_sel_data "run_nuselection_data_noinference.fcl">

    <!ENTITY numjobs_beam_campaign_run2a_fhc "1">
    <!ENTITY numjobs_dirt_campaign_run2a_fhc "1">
    <!ENTITY numjobs_strangeness_campaign_run2a_fhc "1">
    <!ENTITY numjobs_ext_campaign_run2a_fhc "1">
    <!ENTITY numjobs_data_campaign_run2a_fhc "1">
]>

<job>
<project name="&name;">

    <numevents>-1</numevents>
    <os>SL7</os>
    <resource>DEDICATED,OPPORTUNISTIC,OFFSITE</resource>
    <larsoft>
        <tag>&release;</tag>
        <qual>e17:prof</qual>
        <local>&larsoft_tar;</local>
    </larsoft>
    <check>1</check>
    <copy>0</copy>
    <version>prod_&release;</version>
    <memory>4000</memory>
    <disk>20GB</disk>
    <schema>https</schema>
    <maxfilesperjob>1</maxfilesperjob>

    <stage name="beam_campaign_run2a_fhc">
        <inputdef>&input_beam_campaign_run2a_fhc;</inputdef>
        <fcl>&fcl_evtw_00;</fcl>
        <!-- <fcl>&fcl_evtw_01;</fcl> -->
        <!-- <fcl>&fcl_evtw_02;</fcl> -->
        <!-- <fcl>&fcl_evtw_03;</fcl> -->
        <!-- <fcl>&fcl_evtw_04;</fcl> -->
        <!-- <fcl>&fcl_evtw_05;</fcl> -->
        <fcl>&fcl_image;</fcl>
        <!-- <fcl>&fcl_infer;</fcl> -->
        <fcl>&fcl_sel_mc;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run2a_fhc/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam/run2a_fhc/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/beam/run2a_fhc</workdir>
        <datatier>selected</datatier>
        <numjobs>&numjobs_beam_campaign_run2a_fhc;</numjobs>
    </stage>

    <stage name="dirt_campaign_run2a_fhc">
        <inputdef>&input_dirt_campaign_run2a_fhc;</inputdef>
        <fcl>&fcl_evtw_00;</fcl>
        <!-- <fcl>&fcl_evtw_01;</fcl> -->
        <!-- <fcl>&fcl_evtw_02;</fcl> -->
        <!-- <fcl>&fcl_evtw_03;</fcl> -->
        <!-- <fcl>&fcl_evtw_04;</fcl> -->
        <!-- <fcl>&fcl_evtw_05;</fcl> -->
        <fcl>&fcl_image;</fcl>
        <!-- <fcl>&fcl_infer;</fcl> -->
        <fcl>&fcl_sel_mc;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run2a_fhc/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/dirt/run2a_fhc/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/dirt/run2a_fhc</workdir>
        <datatier>selected</datatier>
        <numjobs>&numjobs_dirt_campaign_run2a_fhc;</numjobs>
    </stage>

    <stage name="strangeness_campaign_run2a_fhc">
        <inputdef>&input_strangeness_campaign_run2a_fhc;</inputdef>
        <fcl>&fcl_evtw_00;</fcl>
        <!-- <fcl>&fcl_evtw_01;</fcl> -->
        <!-- <fcl>&fcl_evtw_02;</fcl> -->
        <!-- <fcl>&fcl_evtw_03;</fcl> -->
        <!-- <fcl>&fcl_evtw_04;</fcl> -->
        <!-- <fcl>&fcl_evtw_05;</fcl> -->
        <fcl>&fcl_image;</fcl>
        <!-- <fcl>&fcl_infer;</fcl> -->
        <fcl>&fcl_sel_mc;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/strangeness/run2a_fhc/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/strangeness/run2a_fhc/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/strangeness/run2a_fhc</workdir>
        <datatier>selected</datatier>
        <numjobs>&numjobs_strangeness_campaign_run2a_fhc;</numjobs>
    </stage>

    <stage name="ext_campaign_run2a_fhc">
        <inputdef>&input_ext_campaign_run2a_fhc;</inputdef>
        <fcl>&fcl_image;</fcl>
        <!-- <fcl>&fcl_infer;</fcl> -->
        <fcl>&fcl_sel_data;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/ext/run2a_fhc/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/ext/run2a_fhc/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/ext/run2a_fhc</workdir>
        <datatier>selected</datatier>
        <numjobs>&numjobs_ext_campaign_run2a_fhc;</numjobs>
    </stage>

    <stage name="data_campaign_run2a_fhc">
        <inputdef>&input_data_campaign_run2a_fhc;</inputdef>
        <fcl>&fcl_image;</fcl>
        <!-- <fcl>&fcl_infer;</fcl> -->
        <fcl>&fcl_sel_data;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run2a_fhc/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run2a_fhc/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/data/run2a_fhc</workdir>
        <datatier>selected</datatier>
        <numjobs>&numjobs_data_campaign_run2a_fhc;</numjobs>
    </stage>

</project>
</job>

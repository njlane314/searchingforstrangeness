<?xml version="1.0"?>

<!DOCTYPE project [
    <!ENTITY release "v08_00_00_92">
    <!ENTITY user "nlane">
    <!ENTITY name "numi_run1_campaign">
    <!ENTITY initsrc "runtime/scripts/initsrc.sh">

    <!ENTITY tar_dir "/pnfs/uboone/scratch/users/nlane/tarballs">
    <!ENTITY larsoft_tar "&tar_dir;/strangeness.tar">

    <!ENTITY input_ext "ub_numi_run1_ext_gr">
    <!ENTITY input_data "ub_numi_run1_data_gr">

    <!ENTITY fcl_fullchain_data "run_fullchain_data.fcl">
]>

<job>
<project name="&name;">

    <numevents>-1</numevents>
    <os>SL7</os>
    <resource>DEDICATED,OPPORTUNISTIC,OFFSITE</resource>
    <larsoft>
        <tag>&release;</tag>
        <qual>e17:prof</qual>
        <local>&larsoft_tar;</local>
    </larsoft>
    <check>1</check>
    <copy>0</copy>
    <version>prod_&release;</version>
    <memory>4000</memory>
    <disk>20GB</disk>
    <schema>https</schema>
    <maxfilesperjob>1</maxfilesperjob>

    <stage name="ext">
        <inputdef>&input_ext;</inputdef>
        <fcl>&fcl_fullchain_data;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/ext/run1/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/ext/run1/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/ext/run1</workdir>
        <datatier>selected</datatier>
        <numjobs>25</numjobs>
    </stage>

    <stage name="data">
        <inputdef>&input_data;</inputdef>
        <fcl>&fcl_fullchain_data;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/data/run1</workdir>
        <datatier>selected</datatier>
        <numjobs>25</numjobs>
    </stage>

</project>
</job>

<?xml version="1.0"?>

<!DOCTYPE project [
    <!ENTITY release "v08_00_00_82">
    <!ENTITY user "nlane">
    <!ENTITY name "numi_reco2_run1_fhc_training">
    <!ENTITY initsrc "runtime/scripts/initsrc.sh">

    <!ENTITY tar_dir "/pnfs/uboone/scratch/users/nlane/tarballs">
    <!ENTITY larsoft_tar "&tar_dir;/strangeness.tar">

    <!--
      Run 1 CV training SAM definitions.
      These point at the training-only shards created upstream with
      scripts/train-template.sh or scripts/train-template-pair.sh.
    -->
    <!ENTITY input_beam_detvar_cv_train_shard "nl_run1_fhc_beam_detvar_cv_train_shard">
    <!ENTITY input_strangeness_detvar_cv_train_shard "nl_run1_fhc_strangeness_detvar_cv_train_shard">

    <!--
      Training/test settings:
      - detector-variation jobs run in a single fullchain stage
      - inference is omitted because the checked-in model bundle has not been
        refreshed yet
      - event weights come from the ubsim NuMI slim EventWeight config
      - numjobs is fixed to 25 for a lightweight grid test surface
    -->
    <!ENTITY fcl_fullchain_mc "run_fullchain_noinference.fcl">
]>

<job>
<project name="&name;">

    <numevents>-1</numevents>
    <os>SL7</os>
    <resource>DEDICATED,OPPORTUNISTIC,OFFSITE</resource>
    <larsoft>
        <tag>&release;</tag>
        <qual>e17:prof</qual>
        <local>&larsoft_tar;</local>
    </larsoft>
    <check>1</check>
    <copy>0</copy>
    <version>prod_&release;</version>
    <memory>4000</memory>
    <disk>20GB</disk>
    <schema>https</schema>
    <maxfilesperjob>1</maxfilesperjob>

    <stage name="beam_detvar_cv_train_shard_fullchain">
        <inputdef>&input_beam_detvar_cv_train_shard;</inputdef>
        <fcl>&fcl_fullchain_mc;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam_detvar/run1_fhc/cv_train_shard/fullchain/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/beam_detvar/run1_fhc/cv_train_shard/fullchain/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/beam_detvar/run1_fhc/cv_train_shard/fullchain</workdir>
        <datatier>selected</datatier>
        <numjobs>25</numjobs>
    </stage>

    <stage name="strangeness_detvar_cv_train_shard_fullchain">
        <inputdef>&input_strangeness_detvar_cv_train_shard;</inputdef>
        <fcl>&fcl_fullchain_mc;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/strangeness_detvar/run1_fhc/cv_train_shard/fullchain/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/strangeness_detvar/run1_fhc/cv_train_shard/fullchain/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/strangeness_detvar/run1_fhc/cv_train_shard/fullchain</workdir>
        <datatier>selected</datatier>
        <numjobs>25</numjobs>
    </stage>

</project>
</job>

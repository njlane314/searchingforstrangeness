<?xml version="1.0"?>

<!DOCTYPE project [
    <!ENTITY release "v08_00_00_92">
    <!ENTITY user "nlane">
    <!ENTITY name "numi_run1aot_campaign">
    <!ENTITY initsrc "runtime/scripts/initsrc.sh">

    <!ENTITY tar_dir "/pnfs/uboone/scratch/users/nlane/tarballs">
    <!ENTITY larsoft_tar "&tar_dir;/strangeness.tar">

    <!ENTITY input_data "ub_numi_run1aot_beam_3va_repro_gr">

    <!ENTITY fcl_image "run_imageprod.fcl">
    <!ENTITY fcl_sel_data "run_nuselection_data_slim.fcl">
]>

<job>
<project name="&name;">

    <numevents>-1</numevents>
    <os>SL7</os>
    <resource>DEDICATED,OPPORTUNISTIC,OFFSITE</resource>
    <larsoft>
        <tag>&release;</tag>
        <qual>e17:prof</qual>
        <local>&larsoft_tar;</local>
    </larsoft>
    <check>1</check>
    <copy>0</copy>
    <version>prod_&release;</version>
    <memory>4000</memory>
    <disk>20GB</disk>
    <schema>https</schema>
    <maxfilesperjob>1</maxfilesperjob>

    <stage name="data_image">
        <inputdef>&input_data;</inputdef>
        <fcl>&fcl_image;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1aot/image/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1aot/image/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/data/run1aot/image</workdir>
        <datatier>image</datatier>
        <numjobs>25</numjobs>
    </stage>

    <stage name="data_sel">
        <previousstage>data_image</previousstage>
        <fcl>&fcl_sel_data;</fcl>
        <initsource>&initsrc;</initsource>
        <outdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1aot/sel/out</outdir>
        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/data/run1aot/sel/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/data/run1aot/sel</workdir>
        <datatier>selected</datatier>
        <numjobs>25</numjobs>
    </stage>

</project>
</job>

        <logdir>/pnfs/uboone/scratch/users/&user;/ntuples/&release;/&name;/strangeness_detvar_nominal_train/log</logdir>
        <workdir>/pnfs/uboone/scratch/users/&user;/staging/ntuples/&release;/&name;/strangeness_detvar_nominal_train</workdir>
        <datatier>selected</datatier>
        <numjobs>1</numjobs>
    </stage>

</project>
</job>

#include "microboone_eventweight_service.fcl"
#include "redk2nu_g4_9_2.fcl"
#include "eventweight_microboone_sept24_numi_fhc_oldflux_rw.fcl"
#include "run_nuselection_oldflux.fcl"

process_name: LocalNtupleOldFluxDev

services.TFileService.fileName: "local_ntuple_oldflux_dev.root"
services.UBEventWeight: @local::microboone_eventweight_service
services.NuRandomService: @local::microboone_seedservice

# This local path follows the old-flux redk2nu lookup and the upstream
# oldflux-reweighted NuMI EventWeight configuration from ubsim.

physics.producers.imageprod: {
  module_type: "ImageProducer"
  PFPproducer: @local::standard_producers.PFPproducer
  SLCproducer: @local::standard_producers.SLCproducer
  HITproducer: @local::standard_producers.HITproducer
  WIREproducer: @local::standard_producers.WIREproducer
  MCPproducer: @local::standard_producers.MCPproducer
  BKTproducer: @local::standard_producers.BKTproducer
  SPproducer: @local::standard_producers.SPproducer
  BadChannelFile: "runtime/detector/badchannels.txt"
}

physics.producers.generator: @local::microboone_redk2nu_fhc
physics.producers.eventweightSep24: @local::microboone_eventweight_sept24_oldflux

physics.path1: [ generator, eventweightSep24, imageprod, nuselection ]
physics.trigger_paths: [ path1 ]

LocalNtupleEventWeightAnalysisOldFlux: {
  @table::EventWeightAnalysis
  genieAllUniverses: 100
  ppfxAllUniverses: 100
  useReweightedFlux: true
  eventWeightProcessName00: "LocalNtupleOldFluxDev"
}

physics.filters.nuselection.AnalysisTools.weight: @local::LocalNtupleEventWeightAnalysisOldFlux
physics.filters.nuselection.AnalysisTools.image.InferencePredTag: ""
physics.filters.nuselection.AnalysisTools.image.InferencePerfTag: ""
physics.filters.nuselection.CountWithOpFilter: false
physics.filters.nuselection.OpFilterProcName: ""

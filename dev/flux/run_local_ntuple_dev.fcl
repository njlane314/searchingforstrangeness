#include "microboone_eventweight_service.fcl"
#include "redk2nu.fcl"
#include "eventweight_microboone_sept24_numi_fhc.fcl"
#include "run_nuselection.fcl"

process_name: LocalNtupleDev

services.TFileService.fileName: "local_ntuple_dev.root"
services.UBEventWeight: @local::microboone_eventweight_service
services.NuRandomService: @local::microboone_seedservice

# This local path follows the standard NuMI EventWeight configuration from
# ubsim and the standard g4_10_4 redk2nu lookup from ubana/redk2nu.

physics.producers.imageprod: {
  module_type: "ImageProducer"
  PFPproducer: @local::standard_producers.PFPproducer
  SLCproducer: @local::standard_producers.SLCproducer
  HITproducer: @local::standard_producers.HITproducer
  WIREproducer: @local::standard_producers.WIREproducer
  MCPproducer: @local::standard_producers.MCPproducer
  BKTproducer: @local::standard_producers.BKTproducer
  SPproducer: @local::standard_producers.SPproducer
  BadChannelFile: "runtime/detector/badchannels.txt"
}

physics.producers.generator: @local::microboone_redk2nu_fhc
physics.producers.eventweightSep24: @local::microboone_eventweight_sept24

# Leave inference disabled for this local ntuple test sample until the
# checked-in model bundle has been updated. The downstream test only needs the
# image and event-weight branches for now.
# physics.producers.inferenceprod: {
#   module_type: "InferenceProducer"
#   PlanesTag: "imageprod:CroppedWindow"
#   ScratchDir: ""
#   RuntimeBaseDir: "runtime"
#   DefaultInferenceWrapper: "scripts/inference_wrapper.sh"
#   ModelDefaults: {
#     Arch: "binary:device=cpu,seed=12345,thr=0.0,in_ch=3"
#     WeightsDir: "models/mink_binary"
#   }
#   Models: [
#     {
#       Label: "mink_binary"
#       Checkpoint: "checkpoint_step0010000.pt"
#     }
#   ]
# }

physics.path1: [ generator, eventweightSep24, imageprod, nuselection ]
# physics.path1: [ eventweightSep24, imageprod, inferenceprod, nuselection ]
physics.trigger_paths: [ path1 ]

LocalNtupleEventWeightAnalysis: {
  @table::EventWeightAnalysis
  genieAllUniverses: 100
  ppfxAllUniverses: 100
  useReweightedFlux: false
  eventWeightProcessName00: "LocalNtupleDev"
}

physics.filters.nuselection.AnalysisTools.weight: @local::LocalNtupleEventWeightAnalysis
physics.filters.nuselection.AnalysisTools.image.InferencePredTag: ""
physics.filters.nuselection.AnalysisTools.image.InferencePerfTag: ""
physics.filters.nuselection.CountWithOpFilter: false
physics.filters.nuselection.OpFilterProcName: ""

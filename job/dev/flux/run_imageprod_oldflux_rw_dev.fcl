event_weight_analysis_oldflux_rw_dev: @local::event_weight_analysis_oldflux_rw
event_weight_analysis_oldflux_rw_dev.genieAllUniverses: 100
event_weight_analysis_oldflux_rw_dev.ppfxAllUniverses: 100
event_weight_analysis_oldflux_rw_dev.eventWeightProcessName00: "ImageProdOldFluxRWDev"
